generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
}

enum ProblemSource {
  UVA
  CPE
  GPE
  CUSTOM
}

enum CheckerType {
  EXACT
  IGNORE_TRAILING_WS
  FLOAT
  SPECIAL
}

enum Verdict {
  PENDING
  JUDGING
  AC
  WA
  TLE
  MLE
  RE
  RF
  CE
  PE
  OLE
  SE
}

enum JudgedOn {
  SELF
  REMOTE
}

enum ContestKind {
  CPE
  GPE
  VIRTUAL
  PUBLIC
}

enum ScoringMode {
  ICPC
  SUBTASK
}

enum ParticipantStatus {
  REGISTERED
  RUNNING
  FINISHED
}

enum Plan {
  FREE
  PRO
}

enum BillingPeriod {
  MONTHLY
  YEARLY
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  handle       String   @unique
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  role         Role     @default(USER)
  /// Set by an admin to mark this account as one of their actual tutoring students (distinct
  /// from role=USER, which now also covers anyone who self-registered out of general interest).
  /// Gates the "My Classes" nav link and Class-tracking features.
  isStudent    Boolean  @default(false)
  /// Billing tier. FREE users are capped (submit quota + virtual-attempt count); PRO lifts both.
  /// PRO is only "active" while planExpiresAt is in the future — past that the account behaves as
  /// FREE again until another payment extends the date (see billing.service).
  plan            Plan      @default(FREE)
  planExpiresAt   DateTime?
  /// Lifetime count of submissions made — the FREE tier's quota is enforced against this.
  submitQuotaUsed Int       @default(0)
  settings     Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submissions          Submission[]
  contestParticipants  ContestParticipant[]
  discussions          Discussion[]
  createdAssignments   Assignment[]          @relation("AssignmentCreator")
  assignments          AssignmentAssignee[]  @relation("AssignmentAssigneeUser")
  classSessions        ClassSession[]        @relation("ClassSessionStudent")
  createdClassSessions ClassSession[]        @relation("ClassSessionTeacher")
  notes                Note[]
  payments             Payment[]
  pageViews            PageView[]
  achievements         UserAchievement[]
  notifications        Notification[]

  @@map("users")
}

/// One earned entry per (user, achievement code) — codes are a fixed catalog defined in code
/// (apps/api/src/achievements/catalog.ts), not a DB table, since the set rarely changes and
/// doesn't need admin editing. Evaluated after every AC (see achievements.service.ts).
model UserAchievement {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code     String
  earnedAt DateTime @default(now())

  @@unique([userId, code])
  @@map("user_achievements")
}

/// In-app notification inbox. `type` distinguishes achievement/assignment/etc for icon/styling
/// purposes without needing a DB enum migration to add a new kind. Email is deferred — this is
/// the only delivery channel for now.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@map("notifications")
}

/// A single page load, recorded by a lightweight client-side beacon (see PageviewTracker) for
/// self-hosted traffic analytics. Bot/crawler user agents and known referrer-spam domains are
/// filtered server-side before insertion (see analytics.service.ts recordPageview) — this table
/// should already be clean, not raw unfiltered log data.
model PageView {
  id        String   @id @default(cuid())
  path      String
  /// External referrer only (document.referrer from the browser) — null for direct visits or
  /// same-origin navigation. Already spam-filtered before insertion.
  referrer  String?
  userAgent String?
  userId    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([path])
  @@map("page_views")
}

/// One upgrade payment. With manual bank/LINE Pay transfer, the user submits a claim (PENDING)
/// with a reference note, an admin verifies the money arrived and APPROVES (which extends the
/// user's planExpiresAt), or REJECTS. `method` leaves room for an automated gateway (e.g. ECPay)
/// later without changing this table.
model Payment {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  period     BillingPeriod
  amountNtd  Int
  status     PaymentStatus @default(PENDING)
  method     String        @default("MANUAL")
  reference  String        @default("")
  createdAt  DateTime      @default(now())
  reviewedAt DateTime?
  reviewedBy String?
  /// ECPay's order id (MerchantTradeNo) — set only for method=ECPAY, used to correlate their
  /// async webhooks back to this row. Unique because ECPay requires every order id we send them
  /// to be unique in the first place.
  merchantTradeNo String? @unique
  /// ATM virtual-account details, filled in by the PaymentInfoURL webhook once ECPay issues the
  /// account (separate from — and earlier than — actual payment confirmation via ReturnURL).
  bankCode   String?
  vAccount   String?
  expireDate String?

  @@index([status, createdAt])
  @@map("payments")
}

model Problem {
  id            String        @id @default(cuid())
  // The public problem NUMBER everyone knows (e.g. "100" for "The 3n + 1 problem") — used for
  // display, matching, and dedup. This is NOT the id UVa's own submission system expects.
  uvaId         Int?          @unique
  // UVa's own internal problem id (uHunt calls it "pid"), required by the actual submission form.
  // These two ids are unrelated except by coincidence — e.g. public number 100 has internal pid
  // 36, while UVa's own internal id "100" belongs to a completely different problem ("164 -
  // String Computer"). Submitting with uvaId instead of uvaPid silently judges against the wrong
  // problem's test data (discovered via a real WA/AC discrepancy report — every problem in this
  // table had uvaPid != uvaId). Nullable only for the moment right after uvaId is set and before
  // the uHunt lookup backfills it; judgeViaUva refuses to submit without it.
  uvaPid        Int?
  slug          String        @unique
  title         String
  statementMd   String
  sourceUrl     String?
  inputSpecMd   String        @default("")
  outputSpecMd  String        @default("")
  timeLimitMs   Int           @default(1000)
  memoryLimitKb Int           @default(65536)
  difficulty    Int           @default(1)
  // When true, difficulty came from a human-curated source (e.g. the CPE 必考49題 list, which is
  // an official one-star selection) and derivation backfills must never overwrite it.
  difficultyLocked Boolean    @default(false)
  source        ProblemSource @default(CUSTOM)
  checkerType   CheckerType   @default(IGNORE_TRAILING_WS)
  floatEps      Float?
  visibility    Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  samples          Sample[]
  testCases        TestCase[]
  tags             ProblemTag[]
  submissions      Submission[]
  contestProblems  ContestProblem[]
  discussions      Discussion[]
  assignmentLinks  AssignmentProblem[]
  classHomework    ClassHomework[]
  collectionLinks  CollectionProblem[]
  notes            Note[]

  @@index([uvaId])
  @@map("problems")
}

/// A named, curated problem list (LeetCode-style) — e.g. "CPE 必考 49 題". Distinct from Contest:
/// no timer/scoring, just a themed set of problems to work through at your own pace.
model Collection {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String   @default("")
  createdAt   DateTime @default(now())

  problems CollectionProblem[]

  @@map("collections")
}

model CollectionProblem {
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  problemId    String
  problem      Problem    @relation(fields: [problemId], references: [id], onDelete: Cascade)
  ord          Int        @default(0)

  @@id([collectionId, problemId])
  @@map("collection_problems")
}

model Sample {
  id        String  @id @default(cuid())
  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  ord       Int
  input     String
  output    String

  @@index([problemId])
  @@map("samples")
}

// Hidden judging data for the local (Vercel Sandbox) judge — distinct from Sample, which is only
// ever shown to users on the problem page. A problem is judged locally instead of relayed to UVa
// the moment it has at least one row here (see ProblemsService.recommendNext-style derivation in
// the judge dispatch, not a separate boolean flag — avoids the flag and the actual data ever
// silently drifting apart).
model TestCase {
  id        String  @id @default(cuid())
  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  ord       Int
  input     String
  output    String

  @@unique([problemId, ord])
  @@map("test_cases")
}

model Tag {
  id   String @id @default(cuid())
  slug String @unique
  name String

  problems ProblemTag[]

  @@map("tags")
}

model ProblemTag {
  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([problemId, tagId])
  @@map("problem_tags")
}

model Submission {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId   String
  problem     Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  contestId   String?
  contest     Contest? @relation(fields: [contestId], references: [id], onDelete: SetNull)
  languageKey String
  sourceCode  String
  status      Verdict  @default(PENDING)
  verdict     Verdict  @default(PENDING)
  timeMs      Int?
  memoryKb    Int?
  score       Float    @default(0)
  compileError String?
  judgedOn    JudgedOn @default(REMOTE)
  createdAt   DateTime @default(now())
  judgedAt    DateTime?

  @@index([userId, createdAt])
  @@index([problemId, verdict])
  @@index([contestId, userId, createdAt])
  @@index([verdict, createdAt])
  @@map("submissions")
}

model Contest {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  kind        ContestKind @default(PUBLIC)
  startAt     DateTime?
  durationMin Int         @default(180)
  freezeMin   Int         @default(60)
  penaltyMin  Int         @default(20)
  scoring     ScoringMode @default(ICPC)
  isPublic    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  /// CPE's own published "average correct count" for this sitting (scraped from the exam listing
  /// page), e.g. 1.55 — a difficulty/pass-rate signal independent of anything our own users do.
  avgCorrectCount Float?
  /// Total real-world exam takers for this sitting (CPE's own published figure, e.g. 2446) —
  /// the denominator behind each ContestProblem's "考生答對率".
  totalCandidates Int?

  problems     ContestProblem[]
  participants ContestParticipant[]
  submissions  Submission[]

  @@map("contests")
}

model ContestProblem {
  contestId String
  contest   Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  label     String
  ord       Int
  /// Real-world CPE exam stats for this problem in this specific sitting (scraped from the exam
  /// listing page's per-problem stats table — 繳交次數/作答人數/答對人數). Null for the demo contest
  /// and anything not scraped from the real CPE site.
  submissions Int?
  attempted   Int?
  correct     Int?

  @@id([contestId, problemId])
  @@map("contest_problems")
}

model ContestParticipant {
  id        String            @id @default(cuid())
  contestId String
  contest   Contest           @relation(fields: [contestId], references: [id], onDelete: Cascade)
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt DateTime          @default(now())
  endsAt    DateTime
  status    ParticipantStatus @default(RUNNING)

  @@unique([contestId, userId])
  @@map("contest_participants")
}

model Discussion {
  id        String   @id @default(cuid())
  problemId String
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([problemId, createdAt])
  @@map("discussions")
}

model Assignment {
  id          String    @id @default(cuid())
  title       String
  description String    @default("")
  dueAt       DateTime?
  createdById String
  createdBy   User      @relation("AssignmentCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  problems  AssignmentProblem[]
  assignees AssignmentAssignee[]

  @@map("assignments")
}

model AssignmentProblem {
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  problemId    String
  problem      Problem    @relation(fields: [problemId], references: [id], onDelete: Cascade)
  ord          Int        @default(0)

  @@id([assignmentId, problemId])
  @@map("assignment_problems")
}

model AssignmentAssignee {
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation("AssignmentAssigneeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@id([assignmentId, userId])
  @@map("assignment_assignees")
}

/// A single lesson/tutoring session for one specific student — "Class 1", "Class 2", ... in that
/// student's own personal sequence (not a shared classroom timeline: two students can both have a
/// "Class 3" with entirely different content, taught on different days, at their own pace).
model ClassSession {
  id        String   @id @default(cuid())
  studentId String
  student   User     @relation("ClassSessionStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   User     @relation("ClassSessionTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  number    Int
  title     String   @default("")
  contentMd String   @default("") // what was taught that day
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  homework ClassHomework[]

  @@unique([studentId, number])
  @@map("class_sessions")
}

model ClassHomework {
  id        String       @id @default(cuid())
  classId   String
  class     ClassSession @relation(fields: [classId], references: [id], onDelete: Cascade)
  problemId String
  problem   Problem      @relation(fields: [problemId], references: [id], onDelete: Cascade)
  ord       Int          @default(0)

  @@unique([classId, problemId])
  @@map("class_homework")
}

/// A user's own private notes on a problem — never shown to anyone else.
model Note {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId String
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  content   String   @default("")
  updatedAt DateTime @updatedAt

  @@unique([userId, problemId])
  @@map("notes")
}
