# --- Postgres ---
POSTGRES_USER=oj
POSTGRES_PASSWORD=oj_dev_password
POSTGRES_DB=oj
DATABASE_URL=postgresql://oj:oj_dev_password@localhost:5432/oj?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- MinIO (S3-compatible object storage for test data) ---
MINIO_ROOT_USER=oj_minio
MINIO_ROOT_PASSWORD=oj_minio_password
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=oj-testdata

# --- Auth ---
JWT_ACCESS_SECRET=change_me_access_secret_dev_only
JWT_REFRESH_SECRET=change_me_refresh_secret_dev_only
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
CSRF_SECRET=change_me_csrf_secret_dev_only

# --- Internal service auth (api <-> judge) ---
INTERNAL_SERVICE_TOKEN=change_me_internal_token_dev_only

# --- API ---
API_PORT=4000
WEB_ORIGIN=http://localhost:3000

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Judge worker ---
JUDGE_CONCURRENCY=2
API_INTERNAL_URL=http://localhost:4000

# UVa remote judge (best-effort, optional) — see apps/judge/src/remote/README.md before setting
# these. Use a dedicated bot account, never a personal one. Leave unset to keep isRemoteOnly
# problems returning their current "not configured" message.
UVA_BOT_USERNAME=
UVA_BOT_PASSWORD=
