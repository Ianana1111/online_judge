# --- Postgres ---
POSTGRES_USER=oj
POSTGRES_PASSWORD=oj_dev_password
POSTGRES_DB=oj
DATABASE_URL=postgresql://oj:oj_dev_password@localhost:5432/oj?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_ACCESS_SECRET=change_me_access_secret_dev_only
JWT_REFRESH_SECRET=change_me_refresh_secret_dev_only
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
CSRF_SECRET=change_me_csrf_secret_dev_only

# --- Internal service auth (api <-> judge) ---
INTERNAL_SERVICE_TOKEN=change_me_internal_token_dev_only

# --- API ---
API_PORT=4000
WEB_ORIGIN=http://localhost:3000

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Judge worker ---
JUDGE_CONCURRENCY=2
API_INTERNAL_URL=http://localhost:4000

# UVa remote judge — see apps/judge/src/remote/README.md before setting these. Use a dedicated
# bot account, never a personal one. A problem with no local TestCase rows is judged this way;
# leave unset and such submissions will just return a "not configured" SE.
UVA_BOT_USERNAME=
UVA_BOT_PASSWORD=

# Local judge (Vercel Sandbox) — see apps/judge/src/local/judge.ts. A problem with at least one
# TestCase row is judged this way instead of relaying to UVa.
# JUDGE_SANDBOX_SNAPSHOT_ID comes from `pnpm --filter @oj/judge exec tsx scripts/build-snapshot.ts`.
# Auth: VERCEL_OIDC_TOKEN for local dev (`vercel env pull` in apps/web, ~12h TTL); in
# production/CI use a real access token instead (VERCEL_TOKEN + VERCEL_TEAM_ID + VERCEL_PROJECT_ID —
# see https://vercel.com/docs/sandbox/concepts/authentication).
JUDGE_SANDBOX_SNAPSHOT_ID=
VERCEL_OIDC_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
VERCEL_TOKEN=
